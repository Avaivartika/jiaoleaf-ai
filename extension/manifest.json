{
  "manifest_version": 3,
  "name": "JiaoLeaf AI",
  "version": "0.1.4",
  "description": "AI assistant for SJTU Overleaf and Overleaf-compatible LaTeX projects",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon_16.png",
        "icons/icon_32.png",
        "icons/icon_48.png",
        "icons/icon_128.png",
        "icons/icon_256.png",
        "fonts/*",
        "vendors-*.js",
        "skills/*"
      ],
      "matches": [
        "https://www.overleaf.com/*",
        "https://latex.sjtu.edu.cn/*",
        "https://latex-en.sjtu.edu.cn/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "JiaoLeaf AI",
    "default_icon": {
      "16": "icons/icon_16.png",
      "32": "icons/icon_32.png",
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
    }
  },
  "permissions": [
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://api.openai.com/*"
  ],
  "content_scripts": [
    {
      "world": "MAIN",
      "matches": [
        "https://www.overleaf.com/project/*",
        "https://latex.sjtu.edu.cn/project/*",
        "https://latex-en.sjtu.edu.cn/project/*"
      ],
      "run_at": "document_idle",
      "js": [
        "contentMainScript.js"
      ]
    },
    {
      "matches": [
        "https://www.overleaf.com/project/*",
        "https://latex.sjtu.edu.cn/project/*",
        "https://latex-en.sjtu.edu.cn/project/*"
      ],
      "run_at": "document_idle",
      "js": [
        "contentIsoScript.js"
      ],
      "css": [
        "contentIsoScript.css"
      ]
    }
  ]
}
